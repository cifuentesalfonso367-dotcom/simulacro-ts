generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ScheduleStatus {
  ACTIVE
  CANCELLED
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  name         String
  role         Role       @default(EMPLOYEE)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  schedules    Schedule[]
  auditLogs    AuditLog[]
}

model Schedule {
  id          String         @id @default(uuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  status      ScheduleStatus @default(ACTIVE)
  userId      String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id])

  @@index([startTime, endTime])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // Ej: CREATE_SCHEDULE, UPDATE_USER, LOGIN
  entity    String   // Ej: Schedule, User, Auth
  entityId  String?  // ID del registro afectado
  userId    String   // Usuario que realizó la acción
  details   Json?    // Detalles del cambio en formato JSON
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
